{
  "openapi": "3.0.1",
  "info": {
    "title": "CpuSchedulingBackend",
    "version": "1.0"
  },
  "paths": {
    "/api/Scheduler/schedule": {
      "post": {
        "tags": [
          "Scheduler"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResultDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResultDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResultDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProcessInputDto": {
        "type": "object",
        "properties": {
          "processId": {
            "type": "string",
            "nullable": true
          },
          "arrivalTime": {
            "type": "integer",
            "format": "int32"
          },
          "burstTime": {
            "type": "integer",
            "format": "int32"
          },
          "priority": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProcessStatsDto": {
        "type": "object",
        "properties": {
          "processId": {
            "type": "string",
            "nullable": true
          },
          "waitingTime": {
            "type": "integer",
            "format": "int32"
          },
          "turnaroundTime": {
            "type": "integer",
            "format": "int32"
          },
          "completionTime": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ScheduleRequestDto": {
        "type": "object",
        "properties": {
          "processes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProcessInputDto"
            },
            "nullable": true
          },
          "algorithm": {
            "type": "string",
            "nullable": true
          },
          "quantum": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ScheduleResultDto": {
        "type": "object",
        "properties": {
          "timeline": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TimeSlotDto"
            },
            "nullable": true
          },
          "processStats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProcessStatsDto"
            },
            "nullable": true
          },
          "averageWaitingTime": {
            "type": "number",
            "format": "double"
          },
          "averageTurnaroundTime": {
            "type": "number",
            "format": "double"
          },
          "cpuUtilization": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "TimeSlotDto": {
        "type": "object",
        "properties": {
          "processId": {
            "type": "string",
            "nullable": true
          },
          "startTime": {
            "type": "integer",
            "format": "int32"
          },
          "endTime": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}